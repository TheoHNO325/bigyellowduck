<section class="novel-waizhuan-index novel-main">
  <header class="novel-waizhuan-intro">
    <h1 class="novel-waizhuan-intro__title"><%= page.title %></h1>
    <% if (page.content && page.content.trim()) { %>
    <div class="novel-post__content novel-waizhuan-intro__body"><%- page.content %></div>
    <% } %>
  </header>
<% 
  var tagName = theme.waizhuan_tag || '外传';
  var coll = site.tags.findOne({name: tagName});
  var list = [];
  if (coll && coll.length) {
    coll.posts.sort('source', 1).each(function (p) { list.push(p); });
  }
  var groups = {};
  list.forEach(function (p) {
    var sec = (p.waizhuan_section && String(p.waizhuan_section).trim()) || '未分板块';
    if (!groups[sec]) groups[sec] = [];
    groups[sec].push(p);
  });
  var sectionOrder = Object.keys(groups).sort(function (a, b) {
    if (a === '未分板块') return 1;
    if (b === '未分板块') return -1;
    return a.localeCompare(b, 'zh-CN');
  });
%>
  <% if (!list.length) { %>
  <p class="novel-waizhuan-empty">暂未有外传条目。欢迎按仓库说明投稿。</p>
  <% } %>
  <% sectionOrder.forEach(function (sec, si) { var posts = groups[sec]; %>
  <section class="novel-waizhuan-board" aria-labelledby="waizhuan-board-<%= si %>">
    <h2 class="novel-waizhuan-board__title" id="waizhuan-board-<%= si %>"><%= sec %></h2>
    <div class="novel-waizhuan-board__grid">
      <% posts.forEach(function (p) { %>
      <article class="novel-waizhuan-card novel-card">
        <h3 class="novel-waizhuan-card__title">
          <a href="<%- url_for(p.path) %>"><%= p.title %></a>
        </h3>
        <% if (p.author_display) { %>
        <p class="novel-waizhuan-card__author">文 / <%= p.author_display %></p>
        <% } %>
        <time class="novel-card__time" datetime="<%= post_date_literal(p) %>"><%= post_date_literal(p) %></time>
        <% if (p.excerpt) { %>
        <p class="novel-waizhuan-card__excerpt"><%- strip_html(p.excerpt).substring(0, 120) %><%= strip_html(p.excerpt).length > 120 ? '…' : '' %></p>
        <% } %>
      </article>
      <% }); %>
    </div>
  </section>
  <% }); %>
</section>
