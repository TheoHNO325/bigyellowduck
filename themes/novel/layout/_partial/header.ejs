<header class="novel-header">
  <div class="novel-header__inner">
    <a class="novel-brand" href="<%- url_for('/') %>"><%= config.title %></a>
    <% if (theme.menu && Object.keys(theme.menu).length) { %>
    <nav class="novel-nav" aria-label="站点">
      <% for (var label in theme.menu) { %>
      <a href="<%- url_for(theme.menu[label]) %>"><%= label %></a>
      <% } %>
    </nav>
    <% } %>
    <div class="novel-tools" role="toolbar" aria-label="阅读设置">
      <button type="button" class="novel-tool" data-read-mode="light" title="亮色">亮</button>
      <button type="button" class="novel-tool" data-read-mode="sepia" title="护眼">护</button>
      <button type="button" class="novel-tool" data-read-mode="dark" title="暗色">暗</button>
      <button type="button" class="novel-tool novel-tool--duck" data-duck-toggle title="大黄鸭背景">鸭</button>
      <span class="novel-tools__sep" aria-hidden="true">|</span>
      <button type="button" class="novel-tool" data-font="-1" title="减小字号">A−</button>
      <button type="button" class="novel-tool" data-font="1" title="增大字号">A+</button>
    </div>
  </div>
</header>
