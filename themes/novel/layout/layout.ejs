<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<%- partial('_partial/head') %>
<body class="novel-body<% if (page.layout === 'home') { %> novel-body--home<% } %>">
  <% if (page.layout !== 'home') { %>
  <div class="novel-read-progress" id="read-progress" aria-hidden="true"></div>
  <%- partial('_partial/header') %>
  <div class="novel-wrap">
    <%- body %>
  </div>
  <%- partial('_partial/footer') %>
  <% } else { %>
  <%- body %>
  <% } %>
  <div class="novel-theme-flash" id="novel-theme-flash" aria-hidden="true"></div>
  <script src="<%- url_for('/js/novel.js') %>"></script>
</body>
</html>
